# Django settings for docker-compose
DATABASE_URL=postgres://eventuser_dev:eventpass_dev@db:5432/eventplatform_dev
REDIS_URL=redis://cache:6379/1
SECRET_KEY=your_strong_development_secret_key_here!_change_this
DEBUG=True

# Variables for docker-compose's postgres service (if not set globally)
# These are referenced in the docker-compose.yml for the db service.
# POSTGRES_DB=eventplatform_dev
# POSTGRES_USER=eventuser_dev
# POSTGRES_PASSWORD=eventpass_dev

# Stripe API Keys
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here # For webhook signature verification

# Email Settings (Example for SMTP)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=your_smtp_host (e.g., smtp.gmail.com)
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_smtp_username_or_email
# EMAIL_HOST_PASSWORD=your_smtp_password_or_app_password
# DEFAULT_FROM_EMAIL=Your Name <your_default_from_email@example.com>
# SERVER_EMAIL=your_server_error_email@example.com # For error reports to admins

# Other environment variables if needed
# EXAMPLE_API_KEY=your_api_key_here
