# Next.js frontend environment variables for docker-compose

# This should point to the backend service as accessible from the user's browser
# When running docker-compose, 'localhost' on the host machine maps to services.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Stripe Publishable Key for Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Example of another variable for client-side use
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
