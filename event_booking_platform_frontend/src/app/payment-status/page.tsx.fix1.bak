'use client';

import React, { useEffect, useState } from 'react';
import { useSearchParams, useRouter } from 'next/navigation';
import { useStripe, Elements } from '@stripe/react-stripe-js'; // Import Elements
import { loadStripe } from '@stripe/stripe-js'; // Import loadStripe
import PaymentService from '@/services/PaymentService';
import Link from 'next/link';
import LoadingSpinner from '@/components/common/LoadingSpinner'; // Import common components
import AlertMessage from '@/components/common/AlertMessage';   // Import common components

const PaymentStatusPage = () => {
  // const router = useRouter(); // Not actively used for navigation in this version
  const searchParams = useSearchParams();
  const stripe = useStripe(); // Optional

  const paymentIntentClientSecret = searchParams.get('payment_intent_client_secret');
  const paymentIntentId = searchParams.get('payment_intent');
  const redirectStatus = searchParams.get('redirect_status');

  // Get custom params we passed in the return_url
  const localPaymentId = searchParams.get('payment_id');
  const bookingId = searchParams.get('booking_id');

  const [paymentStatus, setPaymentStatus] = useState<string | null>(null); // Renamed for clarity
  const [displayMessage, setDisplayMessage] = useState<string | null>(null); // Renamed for clarity
  const [loading, setLoading] = useState(true);
  const [isError, setIsError] = useState(false); // To determine AlertMessage type

  useEffect(() => {
    // Ensure stripe is loaded if we intend to use it, or localPaymentId is present
    if (!localPaymentId && !paymentIntentClientSecret) {
        setDisplayMessage("Required payment information is missing from the URL.");
        setIsError(true);
        setLoading(false);
        return;
    }
    if (!stripe && paymentIntentClientSecret) { // If we need stripe for client secret method and it's not loaded
        // Waiting for stripe to load, useEffect will re-run when stripe object is available
        // Alternatively, can show a specific "Stripe.js loading..." message
        return;
    }

    setLoading(true);
    setIsError(false);

    const fetchStatus = async () => {
        // Option 1: Retrieve PaymentIntent status using Stripe.js (requires client_secret from URL)
    // This provides the most up-to-date status directly from Stripe.
    const retrieveWithStripeJS = async () => {
        if (stripe && paymentIntentClientSecret) { // Prioritize Stripe.js if client_secret is available
            try {
                const { paymentIntent: pi } = await stripe.retrievePaymentIntent(paymentIntentClientSecret);
                if (pi) {
                    setPaymentStatus(pi.status);
                    switch (pi.status) {
                        case 'succeeded':
                            setDisplayMessage('Payment successful! Your booking is confirmed.');
                            break;
                        case 'processing':
                            setDisplayMessage('Payment processing. We will update you when payment is received.');
                            break;
                        case 'requires_payment_method':
                        case 'requires_confirmation': // Other non-successful states
                        case 'requires_action':
                            setDisplayMessage('Payment requires further action or failed. Please try again or contact support.');
                            setIsError(true);
                            // router.push(`/checkout/${bookingId}`); // Optional: redirect back to checkout
                            break;
                        default:
                            setDisplayMessage(`Payment status: ${pi.status}. Please contact support if this persists.`);
                            setIsError(true);
                            break;
                    }
                } else {
                     setDisplayMessage('Could not retrieve payment intent details from Stripe.');
                     setIsError(true);
                }
            } catch (stripeJsError: any) {
                console.error("Error retrieving PaymentIntent from Stripe.js:", stripeJsError);
                setDisplayMessage('Error verifying payment status with Stripe.');
                setIsError(true);
            }
        } else if (localPaymentId) {
            // Fallback: Fetch status from your backend using localPaymentId
            try {
                const paymentDetails = await PaymentService.getPaymentDetails(localPaymentId);
                setPaymentStatus(paymentDetails.status); // Assuming backend status aligns or maps to Stripe's
                if (paymentDetails.status === 'succeeded') { // Use 'succeeded' to match Stripe's term
                    setDisplayMessage('Payment successful! Your booking is confirmed.');
                } else if (paymentDetails.status === 'pending' || paymentDetails.status === 'requires_action') {
                    setDisplayMessage('Your payment is currently pending or requires further action.');
                } else if (paymentDetails.status === 'failed' || paymentDetails.status === 'cancelled') {
                    setDisplayMessage('Payment failed or was cancelled. Please try again or contact support.');
                    setIsError(true);
                } else {
                    setDisplayMessage(`Payment status: ${paymentDetails.status}.`);
                }
            } catch (backendError: any) {
                console.error("Error fetching payment status from backend:", backendError);
                setDisplayMessage('Could not retrieve payment status from our records.');
                setIsError(true);
            }
        } else {
            // This case should be caught by the initial check, but as a safeguard:
            setDisplayMessage("Unable to determine payment status due to missing information.");
            setIsError(true);
        }
        setLoading(false);
    };

    fetchStatus();

  }, [stripe, paymentIntentClientSecret, localPaymentId, bookingId] // Removed router from deps as it's not used for navigation here


  if (loading) {
    return <LoadingSpinner message="Verifying payment status..." />;
  }

  return (
    <div className="container mx-auto p-4 md:p-8 text-center max-w-lg">
      <h1 className="text-3xl font-bold text-gray-800 dark:text-white mb-6">Payment Status</h1>
      {displayMessage && <AlertMessage message={displayMessage} type={isError ? 'error' : 'success'} />}

      <div className="mt-8 space-y-4 sm:space-y-0 sm:flex sm:justify-center sm:space-x-4">
        {paymentStatus === 'succeeded' && bookingId && (
          <Link href={`/dashboard`} legacyBehavior> {/* Or a specific booking confirmation page */}
            <a className="btn btn-primary w-full sm:w-auto">View My Bookings</a>
          </Link>
        )}
        {paymentStatus !== 'succeeded' && bookingId && (
          <Link href={`/checkout/${bookingId}`} legacyBehavior>
            <a className="btn btn-secondary w-full sm:w-auto">Try Payment Again</a>
          </Link>
        )}
        <Link href="/" legacyBehavior>
          <a className="btn btn-secondary w-full sm:w-auto">Go to Homepage</a>
        </Link>
      </div>
    </div>
};

// Wrap with Elements provider because useStripe() is used within PaymentStatusPage
const PaymentStatusPageWrapper = () => {
  // Ensure NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is defined or provide a valid default/fallback
  const stripePromise = loadStripe(process.env.NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY || "pk_test_YOUR_DUMMY_KEY");
  return (
    <Elements stripe={stripePromise}>
      <PaymentStatusPage />
    </Elements>
}

export default PaymentStatusPageWrapper;
