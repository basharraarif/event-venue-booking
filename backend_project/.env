# Django settings
# For local development using docker-compose, these often point to services (db, cache)
# For production, these would be your actual production service URLs/credentials.

# Database (PostgreSQL example for production, SQLite for simplest local dev if not using Docker)
DATABASE_URL=postgres://eventuser_prod:eventpass_prod@production_db_host:5432/eventplatform_prod
# Example for local SQLite if not using Docker:
# DATABASE_URL=sqlite:///./db.sqlite3

# Redis Cache
REDIS_URL=redis://production_redis_host:6379/1
# Example for local Redis if not using Docker:
# REDIS_URL=redis://localhost:6379/1


SECRET_KEY=your_strong_production_secret_key_here!_must_be_changed
DEBUG=False # Should be False in production

# Allowed Hosts (comma-separated, e.g., yourdomain.com,www.yourdomain.com)
ALLOWED_HOSTS=your_production_domain.com,www.your_production_domain.com
# For local development with Docker, you might add: localhost,127.0.0.1,.yourinternaldomain

# Variables for docker-compose's postgres service (these are build-time args for the db service in docker-compose)
# These are NOT directly used by Django if DATABASE_URL is set, but good for consistency.
POSTGRES_DB=eventplatform_prod
POSTGRES_USER=eventuser_prod
POSTGRES_PASSWORD=eventpass_prod

# Stripe API Keys (use production keys for production environment)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Email Settings for Production (Example for SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=your_production_smtp_host
EMAIL_PORT=587
EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False # Mutually exclusive with TLS
EMAIL_HOST_USER=your_production_smtp_username
EMAIL_HOST_PASSWORD=your_production_smtp_password
DEFAULT_FROM_EMAIL="Event Platform BD <noreply@your_production_domain.com>"
SERVER_EMAIL="Server Errors <server-errors@your_production_domain.com>" # For error reports

# Other environment variables if needed
# EXAMPLE_API_KEY=your_api_key_here
# DJANGO_SETTINGS_MODULE=event_booking_platform_backend.settings # Often set in Dockerfile or WSGI server config
DATABASE_URL=postgres://user:password@localhost:5433/event_booking_db
